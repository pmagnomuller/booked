<div class="bg-white py-6">
  <div class="container mx-auto px-4">
    <div class="flex justify-between items-center mb-8">
      <h1 class="text-3xl font-bold text-gray-900">Find your next stay</h1>
      
      <div>
        <% if logged_in? %>
          <%= link_to "Add New Property", new_property_path, class: "bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-md" %>
        <% end %>
      </div>
    </div>
    
    <!-- Search Form -->
    <div class="bg-gray-100 p-6 rounded-lg mb-8">
      <%= form_with url: search_path, method: :get, class: "flex flex-wrap gap-4" do |f| %>
        <div class="flex-grow min-w-[200px]">
          <%= f.text_field :query, placeholder: "Where are you going?", class: "w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" %>
        </div>
        
        <div class="flex-grow min-w-[150px]">
          <%= f.number_field :min_price, placeholder: "Min Price", min: 0, class: "w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" %>
        </div>
        
        <div class="flex-grow min-w-[150px]">
          <%= f.number_field :max_price, placeholder: "Max Price", min: 0, class: "w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" %>
        </div>
        
        <div>
          <%= f.submit "Search", class: "bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-md" %>
        </div>
      <% end %>
    </div>
    
    <!-- Property Listings -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% if @properties.any? %>
        <% @properties.each do |property| %>
          <div class="bg-white rounded-lg overflow-hidden shadow-md hover:shadow-lg transition-shadow duration-300">
            <% if property.images.attached? %>
              <%= image_tag property.images.first, class: "w-full h-48 object-cover" %>
            <% else %>
              <div class="w-full h-48 bg-gray-200 flex items-center justify-center">
                <p class="text-gray-500">No image available</p>
              </div>
            <% end %>
            
            <div class="p-4">
              <h2 class="text-xl font-semibold mb-2"><%= link_to property.title, property, class: "text-blue-600 hover:text-blue-800" %></h2>
              
              <div class="flex items-center mb-2">
                <span class="text-yellow-500 mr-1">
                  <% (property.average_rating.to_i).times do %>★<% end %>
                  <% (5 - property.average_rating.to_i).times do %>☆<% end %>
                </span>
                <span class="text-gray-600"><%= property.average_rating.round(1) %></span>
              </div>
              
              <p class="text-gray-600 mb-2"><%= property.city %>, <%= property.country %></p>
              <p class="text-gray-700 mb-3 truncate"><%= property.description %></p>
              <p class="text-lg font-bold">$<%= property.price_per_night %> / night</p>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="col-span-full py-12 text-center">
          <p class="text-gray-500 text-xl">No properties found</p>
        </div>
      <% end %>
    </div>
  </div>
</div>
